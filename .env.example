# ── Required (startup fails if missing) ──
DATABASE_URL=
JWT_SECRET=
JWT_EXPIRES_IN=

# ── Server (optional — sensible defaults) ──
PORT=3001
CLIENT_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173,https://verifyng.vercel.app
MAX_BODY_SIZE=10485760
BCRYPT_ROUNDS=12

# ── Email — Brevo (primary — sends over HTTPS, works on hosts that block
# outbound SMTP, like Render's free tier). Verify a Single Sender at
# https://app.brevo.com (no domain purchase required), generate an API key
# under Settings → SMTP & API, and authorize your server's outbound IP(s)
# at https://app.brevo.com/security/authorised_ips. ──
BREVO_API_KEY=
BREVO_FROM=

# ── Email — Resend (preferred once a verified sending domain exists) ──
# NOTE: Resend requires a verified sending domain. Until the project has a
# domain, leave these unset — Brevo above (or SMTP below) is used instead.
RESEND_API_KEY=
RESEND_FROM=VerifyNG <noreply@your-domain.com>

# ── Email — SMTP (local-dev fallback only — most PaaS free tiers, including
# Render, block outbound SMTP ports, so this won't work in production) ──
# For Google: enable 2FA, then generate an App Password at https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=

# SMTP timeouts (ms)
SMTP_CONNECTION_TIMEOUT=10000
SMTP_GREETING_TIMEOUT=10000
SMTP_SOCKET_TIMEOUT=15000

# ── AI Feature (optional — summarization degrades gracefully if unset) ──
AI_API_KEY=
AI_API_URL=https://api.openai.com/v1
AI_MODEL=gpt-4o-mini
AI_TIMEOUT=15000
AI_TEMPERATURE=0.3

# ── Rate Limits (count / window-ms) ──
RATE_LIMIT_REVIEW_MAX=5
RATE_LIMIT_REVIEW_WINDOW=3600000
RATE_LIMIT_SEARCH_MAX=20
RATE_LIMIT_SEARCH_WINDOW=60000
RATE_LIMIT_LOGIN_MAX=10
RATE_LIMIT_LOGIN_WINDOW=900000
RATE_LIMIT_ACTION_MAX=30
RATE_LIMIT_ACTION_WINDOW=60000
RATE_LIMIT_CLAIM_MAX=5
RATE_LIMIT_CLAIM_WINDOW=3600000
RATE_LIMIT_REPORT_MAX=5
RATE_LIMIT_REPORT_WINDOW=3600000
RATE_LIMIT_CLEANUP_INTERVAL=600000

# ── Misc ──
FEATURED_VENDOR_COUNT=3
ADMIN_IP_ALLOWLIST=
COOKIE_MAX_AGE_SECONDS=604800
# MUST be true in production behind Cloudflare/NGINX so rate limiting sees real
# client IPs; keep false when the server is directly exposed (prevents IP spoofing).
TRUST_PROXY=false

# ── Seed Script (optional — uses random passwords if unset) ──
SEED_TEST_USER_PASSWORD=
SEED_ADMIN_PASSWORD=
SEED_DEV_PASSWORD=

# ── Client ──
VITE_API_BASE_URL=http://localhost:3001
