{
  "name": "verifyng-server",
  "version": "1.0.0",
  "description": "VerifyNG backend server — Node.js with native HTTP",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch --env-file=../.env src/index.ts",
    "build": "tsc",
    "start": "node --env-file=../.env dist/index.js",
    "test": "vitest run",
    "promote-admin": "tsx prisma/promote.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.9.0",
    "bcrypt": "^5.1.1",
    "jsonwebtoken": "^9.0.2",
    "nodemailer": "^9.0.3",
    "resend": "^6.12.4"
  },
  "overrides": {
    "tar": "^7.5.16"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "^22.15.0",
    "@types/nodemailer": "^6.4.17",
    "prisma": "^6.9.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.10"
  }
}
